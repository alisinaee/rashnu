{
  "manifest_version": 3,
  "name": "Rashnu",
  "version": "0.0.6",
  "description": "Compare listings across Basalam, Digikala, Torob, Technolife, Emalls, Divar, Amazon, and eBay.",
  "icons": {
    "16": "assets/extension-icons/icon-inactive-16.png",
    "32": "assets/extension-icons/icon-inactive-32.png",
    "48": "assets/extension-icons/icon-inactive-48.png",
    "128": "assets/extension-icons/icon-inactive-128.png"
  },
  "permissions": ["activeTab", "storage", "scripting", "tabs", "sidePanel", "downloads", "webNavigation"],
  "host_permissions": [
    "https://www.digikala.com/*",
    "https://api.digikala.com/*",
    "https://torob.com/*",
    "https://api.torob.com/*",
    "https://www.technolife.com/*",
    "https://emalls.ir/*",
    "https://basalam.com/*",
    "https://www.basalam.com/*",
    "https://divar.ir/*",
    "https://api.divar.ir/*",
    "https://map.divarcdn.com/*",
    "https://api.ebay.com/*",
    "https://www.ebay.com/*",
    "https://creatorsapi.amazon/*",
    "https://creatorsapi.auth.us-west-2.amazoncognito.com/*",
    "https://www.amazon.com/*",
    "https://r.jina.ai/*",
    "https://translate.googleapis.com/*",
    "http://127.0.0.1:45173/*",
    "http://localhost:45173/*"
  ],
  "action": {
    "default_title": "Rashnu",
    "default_icon": {
      "16": "assets/extension-icons/icon-inactive-16.png",
      "32": "assets/extension-icons/icon-inactive-32.png",
      "48": "assets/extension-icons/icon-inactive-48.png"
    }
  },
  "side_panel": {
    "default_path": "src/panel/panel.html"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.digikala.com/*",
        "https://torob.com/*",
        "https://www.technolife.com/*",
        "https://emalls.ir/*",
        "https://basalam.com/*",
        "https://www.basalam.com/*",
        "https://www.amazon.com/*",
        "https://www.ebay.com/*"
      ],
      "js": [
        "src/lib/logger.js",
        "src/lib/normalize.js",
        "src/lib/match.js",
        "src/lib/extract-listing-cards.js",
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
