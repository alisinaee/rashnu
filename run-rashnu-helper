#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
HELPER_SCRIPT="$ROOT_DIR/scripts/rashnu_log_helper.py"
ARTIFACT_DIR="$ROOT_DIR/research/artifacts/rashnu"
LAUNCH_AGENT_ID="com.rashnu.log-helper"
LAUNCH_AGENT_DIR="$HOME/Library/LaunchAgents"
LAUNCH_AGENT_PATH="$LAUNCH_AGENT_DIR/$LAUNCH_AGENT_ID.plist"
STDOUT_PATH="$ARTIFACT_DIR/rashnu-helper-launchd.out.log"
STDERR_PATH="$ARTIFACT_DIR/rashnu-helper-launchd.err.log"
UNAME="$(uname -s 2>/dev/null || echo unknown)"

ensure_artifacts() {
  mkdir -p "$ARTIFACT_DIR"
}

resolve_python() {
  local python_path
  if python_path="$(command -v python3 2>/dev/null)"; then
    echo "$python_path"
    return 0
  fi
  if python_path="$(command -v python 2>/dev/null)"; then
    echo "$python_path"
    return 0
  fi
  echo "Python 3 was not found on PATH." >&2
  exit 1
}

write_launch_agent() {
  mkdir -p "$LAUNCH_AGENT_DIR"
  ensure_artifacts
  cat >"$LAUNCH_AGENT_PATH" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>$LAUNCH_AGENT_ID</string>
    <key>ProgramArguments</key>
    <array>
      <string>$(resolve_python)</string>
      <string>$HELPER_SCRIPT</string>
    </array>
    <key>WorkingDirectory</key>
    <string>$ROOT_DIR</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>$STDOUT_PATH</string>
    <key>StandardErrorPath</key>
    <string>$STDERR_PATH</string>
  </dict>
</plist>
PLIST
}

unload_launch_agent() {
  launchctl bootout "gui/$UID" "$LAUNCH_AGENT_PATH" >/dev/null 2>&1 || true
  launchctl unload -w "$LAUNCH_AGENT_PATH" >/dev/null 2>&1 || true
}

load_launch_agent() {
  launchctl bootstrap "gui/$UID" "$LAUNCH_AGENT_PATH" >/dev/null 2>&1 || launchctl load -w "$LAUNCH_AGENT_PATH"
  launchctl enable "gui/$UID/$LAUNCH_AGENT_ID" >/dev/null 2>&1 || true
  launchctl kickstart -k "gui/$UID/$LAUNCH_AGENT_ID" >/dev/null 2>&1 || true
}

print_status() {
  if curl -fsS "http://127.0.0.1:45173/health" >/dev/null 2>&1; then
    echo "Rashnu log helper: running"
  else
    echo "Rashnu log helper: not running"
  fi
  if [[ "$UNAME" == "Darwin" ]]; then
    if [[ -f "$LAUNCH_AGENT_PATH" ]]; then
      echo "Autostart: installed ($LAUNCH_AGENT_PATH)"
    else
      echo "Autostart: not installed"
    fi
  fi
}

usage() {
  cat <<USAGE
Usage: ./run-rashnu-helper [command]

Commands:
  (no command)            Run logger helper in foreground
  --install-autostart     Install macOS LaunchAgent and start helper
  --uninstall-autostart   Remove LaunchAgent autostart
  --status                Show helper and autostart status
  --help                  Show this message

Windows:
  Use .\\run-rashnu-helper.ps1 instead.
USAGE
}

case "${1:-}" in
  "")
    cd "$ROOT_DIR"
    exec "$(resolve_python)" "$HELPER_SCRIPT"
    ;;
  --install-autostart)
    if [[ "$UNAME" != "Darwin" ]]; then
      echo "Autostart install from this launcher is only supported on macOS." >&2
      echo "On Windows use .\\run-rashnu-helper.ps1 -InstallAutostart" >&2
      exit 1
    fi
    write_launch_agent
    unload_launch_agent
    load_launch_agent
    echo "Installed and started autostart logger: $LAUNCH_AGENT_ID"
    ;;
  --uninstall-autostart)
    if [[ "$UNAME" != "Darwin" ]]; then
      echo "Autostart uninstall from this launcher is only supported on macOS." >&2
      echo "On Windows use .\\run-rashnu-helper.ps1 -UninstallAutostart" >&2
      exit 1
    fi
    unload_launch_agent
    rm -f "$LAUNCH_AGENT_PATH"
    echo "Removed autostart logger: $LAUNCH_AGENT_ID"
    ;;
  --status)
    print_status
    ;;
  --help|-h)
    usage
    ;;
  *)
    echo "Unknown command: $1" >&2
    usage >&2
    exit 1
    ;;
esac
